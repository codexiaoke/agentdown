# DeepSeek model settings
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Backend server settings
AGENTDOWN_BACKEND_HOST=127.0.0.1
AGENTDOWN_BACKEND_PORT=8000

# Frontend CORS origins
AGENTDOWN_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Agno paused run storage
AGENTDOWN_AGNO_PAUSED_RUN_STORE=redis
AGENTDOWN_REDIS_URL=redis://127.0.0.1:6379/0
AGENTDOWN_AGNO_PAUSED_RUN_TTL_SECONDS=3600
