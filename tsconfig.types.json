{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.types.tsbuildinfo",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/demo/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.test.vue",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.spec.vue"
  ]
}
