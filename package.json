{
  "name": "@codexiaoke/agentdown",
  "version": "0.1.0",
  "description": "Reactive agent-native markdown UI runtime for Vue, powered by markdown-it and @chenglou/pretext.",
  "type": "module",
  "license": "MIT",
  "author": "xiaoke",
  "homepage": "https://github.com/codexiaoke/agentdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codexiaoke/agentdown.git"
  },
  "bugs": {
    "url": "https://github.com/codexiaoke/agentdown/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vite",
    "agent",
    "agui",
    "markdown",
    "pretext",
    "runtime",
    "npm"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.44",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-math": "^5.2.1",
    "mermaid": "^11.14.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  }
}
